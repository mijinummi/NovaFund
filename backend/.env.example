# Database Configuration
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=password
DATABASE_NAME=novafund

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_DEFAULT_TTL=300
REDIS_MAX_KEYS=1000

# JWT Configuration
JWT_SECRET=your-secret-key-here
JWT_EXPIRATION=86400

# Server Configuration
PORT=3000
API_PREFIX=api/v1
NODE_ENV=development

# Stellar Blockchain Configuration
STELLAR_NETWORK=testnet
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_BACKUP_RPC_URLS=https://soroban-testnet.stellar.org:443,https://stellar-testnet.rpc.explorer.ai/api
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
STELLAR_SPONSOR_SECRET_KEY=S... (replace with actual sponsor secret key)

# RPC Fallback Configuration
RPC_CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
RPC_CIRCUIT_BREAKER_RECOVERY_TIMEOUT=60000
RPC_CIRCUIT_BREAKER_MONITORING_PERIOD=30000
RPC_HEALTH_CHECK_INTERVAL=30000
RPC_REQUEST_TIMEOUT=10000

# Contract IDs (replace with actual deployed contract addresses)
PROJECT_LAUNCH_CONTRACT_ID=CD...
ESCROW_CONTRACT_ID=CD...
PROFIT_DISTRIBUTION_CONTRACT_ID=CD...
SUBSCRIPTION_POOL_CONTRACT_ID=CD...
GOVERNANCE_CONTRACT_ID=CD...
REPUTATION_CONTRACT_ID=CD...
TOKEN_FACTORY_CONTRACT_ID=CD...
STELLAR_USDC_CONTRACT_ID=
STELLAR_EURC_CONTRACT_ID=

# Sentry
SENTRY_DSN=https://<key>@o<org>.ingest.sentry.io/<project>

# Indexer Configuration
INDEXER_POLL_INTERVAL_MS=5000
INDEXER_REORG_DEPTH_THRESHOLD=5
INDEXER_MAX_EVENTS_PER_FETCH=100
INDEXER_RETRY_ATTEMPTS=3
INDEXER_RETRY_DELAY_MS=1000
# Optional: Start from specific ledger (for initial sync)
# INDEXER_START_LEDGER=1000000

# Bridge Configuration
ETHERSCAN_API_KEY=your-etherscan-api-key
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
# Poll interval is hardcoded to 30s via @Cron(EVERY_30_SECONDS)

# ─── Support / Live Chat Integration ───────────────────────────────
# Which provider to use by default (INTERCOM | ZENDESK)
SUPPORT_DEFAULT_PROVIDER=INTERCOM

# Intercom
INTERCOM_ACCESS_TOKEN=
INTERCOM_WORKSPACE_ID=
INTERCOM_ADMIN_ID=

# Zendesk
ZENDESK_SUBDOMAIN=
ZENDESK_EMAIL=
ZENDESK_API_TOKEN=
ZENDESK_AGENT_ID=
ZENDESK_ON_CHAIN_CONTEXT_FIELD_ID=
